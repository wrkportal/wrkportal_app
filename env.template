# ============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# Production secrets should be stored in AWS SSM Parameter Store

# DATABASE CONFIGURATION (AWS Aurora Serverless v2)
DATABASE_URL="postgresql://username:password@your-aurora-cluster.us-east-1.rds.amazonaws.com:5432/wrkportal?sslmode=require"

# NEXTAUTH CONFIGURATION
NEXTAUTH_URL="https://wrkportal.com"
NEXTAUTH_SECRET="generate-using-openssl-rand-base64-32"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# EMAIL SERVICE (AWS SES)
SMTP_HOST="email-smtp.us-east-1.amazonaws.com"
SMTP_PORT="587"
SMTP_USER="ses-smtp-username"
SMTP_PASS="ses-smtp-password"
EMAIL_FROM="noreply@wrkportal.com"

# AI CONFIGURATION (AWS Bedrock)
AI_PROVIDER="aws-bedrock"
AWS_REGION="us-east-1"
# Bedrock uses IAM role-based auth — no API keys needed when running on ECS

# AWS S3 Configuration (File Storage)
S3_BUCKET_NAME="wrkportal-production-files"
# S3 uses IAM role-based auth — no access keys needed when running on ECS

# REDIS CACHE (AWS ElastiCache)
REDIS_URL="redis://your-elasticache-endpoint:6379"

# AI FEATURES TOGGLE
AI_FEATURES_ENABLED="true"
AI_CHAT_ASSISTANT_ENABLED="true"
AI_RISK_PREDICTION_ENABLED="true"
AI_BUDGET_FORECASTING_ENABLED="true"

# REPORTING STUDIO ENCRYPTION KEY
# Generate with: openssl rand -base64 32
# IMPORTANT: Store in AWS SSM Parameter Store for production
REPORTING_STUDIO_ENCRYPTION_KEY="generate-using-openssl-rand-base64-32"

# INTEGRATION ENCRYPTION KEY
# Used to encrypt third-party integration credentials
INTEGRATION_ENCRYPTION_KEY="generate-using-openssl-rand-base64-32"

# STRIPE PAYMENT CONFIGURATION
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# CI/CD Webhook Configuration (optional)
GITHUB_WEBHOOK_SECRET="your-github-webhook-secret-here"

# CRON JOB SECRET
CRON_SECRET="generate-a-random-secret"
