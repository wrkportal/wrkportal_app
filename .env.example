# =============================================================================
# wrkportal Production Environment Variables
# =============================================================================
# All values should be stored in AWS SSM Parameter Store and injected via
# ECS Task Definition secrets. This file is for documentation only.
# =============================================================================

# --- Database (AWS Aurora Serverless v2) ---
DATABASE_URL="postgresql://user:password@wrkportal-prod.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/wrkportal?schema=public"

# --- Authentication (NextAuth / Auth.js) ---
NEXTAUTH_URL="https://app.wrkportal.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AWS Core ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- AWS S3 (File Storage) ---
S3_BUCKET_NAME="wrkportal-production-files"

# --- AWS ElastiCache Redis ---
REDIS_URL="redis://wrkportal-redis.xxxxx.use1.cache.amazonaws.com:6379"

# --- AWS SES (Email) ---
SMTP_HOST="email-smtp.us-east-1.amazonaws.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@wrkportal.com"

# --- AWS Bedrock (AI) ---
AI_PROVIDER="aws-bedrock"
AWS_BEDROCK_REGION="us-east-1"
AWS_BEDROCK_MODEL_ID="anthropic.claude-3-5-sonnet-20241022-v2:0"
AWS_BEDROCK_EMBEDDING_MODEL_ID="amazon.titan-embed-text-v2:0"

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Encryption ---
ENCRYPTION_MASTER_KEY="generate-with-openssl-rand-base64-32"
INTEGRATION_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"
REPORTING_STUDIO_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# --- Cron Job Security ---
CRON_SECRET="generate-with-openssl-rand-base64-32"

# --- Integrations (Optional) ---
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
HUBSPOT_API_KEY=""
